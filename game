// ─── SNAKE DRAFT ORDER ────────────────────────────────────────────────────────

// Generates the full sequence of (playerIndex, guessNumber) for one round.
// Snake: 3 players, 2 guesses => 0,1,2, 2,1,0
// 3 players, 3 guesses => 0,1,2, 2,1,0, 0,1,2
function buildSnakeOrder(numPlayers, guessesPerRound) {
const order = [];
for (let g = 0; g < guessesPerRound; g++) {
const forward = g % 2 === 0;
if (forward) {
for (let p = 0; p < numPlayers; p++) order.push(p);
} else {
for (let p = numPlayers - 1; p >= 0; p–) order.push(p);
}
}
return order; // Array of player indices
}

