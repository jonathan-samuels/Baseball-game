<script type="text/babel">
const { useState, useEffect, useRef, useCallback, useMemo } = React;

// ─── CONSTANTS ───────────────────────────────────────────────────────────────

const STAT_CATEGORIES = [
{ group: ‘Batting’, stats: [
{ label: ‘Home Runs’,       api: ‘homeRuns’,          statGroup: ‘hitting’,  fmt: (v) => v },
{ label: ‘RBI’,             api: ‘rbi’,               statGroup: ‘hitting’,  fmt: (v) => v },
{ label: ‘Hits’,            api: ‘hits’,              statGroup: ‘hitting’,  fmt: (v) => v },
{ label: ‘Batting Average’, api: ‘battingAverage’,    statGroup: ‘hitting’,  fmt: (v) => parseFloat(v).toFixed(3) },
{ label: ‘OPS’,             api: ‘onBasePlusSlugging’, statGroup: ‘hitting’, fmt: (v) => parseFloat(v).toFixed(3) },
{ label: ‘Stolen Bases’,    api: ‘stolenBases’,       statGroup: ‘hitting’,  fmt: (v) => v },
]},
{ group: ‘Pitching’, stats: [
{ label: ‘Wins’,            api: ‘wins’,              statGroup: ‘pitching’, fmt: (v) => v },
{ label: ‘ERA’,             api: ‘earnedRunAverage’,  statGroup: ‘pitching’, fmt: (v) => parseFloat(v).toFixed(2) },
{ label: ‘Strikeouts’,      api: ‘strikeouts’,        statGroup: ‘pitching’, fmt: (v) => v },
{ label: ‘Saves’,           api: ‘saves’,             statGroup: ‘pitching’, fmt: (v) => v },
]},
];

const ALL_STATS = STAT_CATEGORIES.flatMap(g => g.stats.map(s => ({ …s, group: g.group })));

const TIME_PERIODS = [
{ label: ‘Last 5 Years’,  value: ‘last5’,   startYear: new Date().getFullYear() - 5 },
{ label: ‘Since 2000’,    value: ‘since2000’, startYear: 2000 },
{ label: ‘Since 1990’,    value: ‘since1990’, startYear: 1990 },
{ label: ‘All Time’,      value: ‘alltime’,   startYear: 1969 },
];

const currentYear = new Date().getFullYear() - 1; // use last completed season

// ─── UTILS ───────────────────────────────────────────────────────────────────

const rand4 = () => Math.random().toString(36).substring(2, 6).toUpperCase().replace(/[^A-Z0-9]/g, ‘X’).padEnd(4,‘X’).substring(0,4);

const normalizeName = (name) =>
name.toLowerCase().trim()
.normalize(‘NFD’).replace(/[\u0300-\u036f]/g, ‘’)
.replace(/[^a-z0-9 ]/g, ‘’);

// ─── API LAYER ────────────────────────────────────────────────────────────────

// Fetch leaders for a single season
const fetchSingleSeason = async (leaderCategory, statGroup, season) => {
const url = `https://statsapi.mlb.com/api/v1/stats/leaders?leaderCategories=${leaderCategory}&season=${season}&leaderGameTypes=R&limit=500&statGroup=${statGroup}`;
const res = await fetch(url);
if (!res.ok) throw new Error(`HTTP ${res.status}`);
const data = await res.json();
const leaders = data?.leagueLeaders?.[0]?.leaders ?? [];
return leaders.map(l => ({
name: l.person?.fullName ?? ‘’,
playerId: l.person?.id,
value: parseFloat(l.value ?? 0),
}));
};

// For cumulative stats (HR, RBI, etc.) we sum across seasons.
// For rate stats (AVG, ERA, OPS) we take the career-style best weighted —
// for simplicity, we fetch them as career stats filtered by range using per-season approach then pick the player’s TOTAL from each season.
const RATE_STATS = new Set([‘battingAverage’, ‘onBasePlusSlugging’, ‘earnedRunAverage’]);
const BASE_STATS = { ‘battingAverage’: ‘hits’, ‘onBasePlusSlugging’: null, ‘earnedRunAverage’: null };

const aggregateSeasons = async (leaderCategory, statGroup, startYear, onProgress) => {
const endYear = currentYear;
const seasons = [];
for (let y = startYear; y <= endYear; y++) seasons.push(y);

const isRate = RATE_STATS.has(leaderCategory);

// Map: playerId -> { name, total, atBats (for avg), innings (for era), ops numerator stuff }
const playerMap = {};

for (let i = 0; i < seasons.length; i++) {
onProgress && onProgress(Math.round(((i + 1) / seasons.length) * 100));
try {
const rows = await fetchSingleSeason(leaderCategory, statGroup, seasons[i]);
for (const row of rows) {
if (!row.playerId || !row.name) continue;
if (!playerMap[row.playerId]) playerMap[row.playerId] = { name: row.name, total: 0, seasonCount: 0 };
if (isRate) {
// For rate stats: store an array of season values, we’ll compute weighted average later
if (!playerMap[row.playerId].values) playerMap[row.playerId].values = [];
playerMap[row.playerId].values.push(row.value);
} else {
playerMap[row.playerId].total += row.value;
}
playerMap[row.playerId].seasonCount++;
}
} catch (e) {
// Skip seasons that fail (some early seasons may not have all stats)
console.warn(`Season ${seasons[i]} fetch failed for ${leaderCategory}:`, e.message);
}
}

let players = Object.values(playerMap);

if (isRate) {
// Average across seasons they played
players = players.map(p => ({ …p, total: p.values && p.values.length ? p.values.reduce((a,b)=>a+b,0)/p.values.length : 0 }));
}

// For ERA and AVG lower is better — sort ascending
const ascending = leaderCategory === ‘earnedRunAverage’ || leaderCategory === ‘battingAverage’;
// ERA: filter out players with very few entries (probably relievers with tiny samples)
let filtered = players.filter(p => p.total > 0);
if (leaderCategory === ‘earnedRunAverage’) filtered = filtered.filter(p => p.seasonCount >= 2);
if (leaderCategory === ‘battingAverage’) filtered = filtered.filter(p => p.seasonCount >= 1);

filtered.sort((a, b) => ascending ? a.total - b.total : b.total - a.total);

return filtered.slice(0, 150).map((p, i) => ({ rank: i + 1, name: p.name, value: p.total }));
};

// Main fetch entry point
const fetchLeaderboard = async (statApiKey, statGroup, timePeriodValue, onProgress) => {
const period = TIME_PERIODS.find(p => p.value === timePeriodValue);
if (!period) throw new Error(‘Unknown time period’);

onProgress && onProgress(0);
const rows = await aggregateSeasons(statApiKey, statGroup, period.startYear, onProgress);
onProgress && onProgress(100);
return rows; // [{rank, name, value}]
};

// ─── SHARED STATE (localStorage + BroadcastChannel) ───────────────────────────

const STORAGE_KEY = ‘the100game_rooms’;

const getRooms = () => { try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || ‘{}’); } catch { return {}; } };
const saveRooms = (rooms) => localStorage.setItem(STORAGE_KEY, JSON.stringify(rooms));

const getRoom = (code) => getRooms()[code] ?? null;
const setRoom = (code, data) => {
const rooms = getRooms();
rooms[code] = { …data, updatedAt: Date.now() };
saveRooms(rooms);
};

// ─── SMALL COMPONENTS ─────────────────────────────────────────────────────────

const Spinner = ({ size = 20 }) => (

  <div className="spin" style={{ width: size, height: size, border: `2px solid rgba(255,255,255,0.2)`, borderTopColor: '#f5c842', borderRadius: '50%', display: 'inline-block' }} />
);

const RankBadge = ({ rank }) => rank >= 1 && rank <= 100
? <span className="badge-hit">#{rank}</span>
: <span className="badge-miss">{rank > 100 ? `#${rank}` : ‘Not Found’}</span>;

const ProgressBar = ({ pct }) => (

  <div className="progress-track">
    <div className="progress-fill" style={{ width: `${pct}%` }} />
  </div>
);

// ─── AUTOCOMPLETE INPUT ────────────────────────────────────────────────────────

function AutocompleteInput({ value, onChange, leaderboard, onSubmit, disabled }) {
const [open, setOpen] = useState(false);
const [selectedIdx, setSelectedIdx] = useState(-1);
const inputRef = useRef(null);

const suggestions = useMemo(() => {
if (!value || value.length < 2 || !leaderboard) return [];
const norm = normalizeName(value);
return leaderboard.filter(p => normalizeName(p.name).includes(norm)).slice(0, 8);
}, [value, leaderboard]);

useEffect(() => { setOpen(suggestions.length > 0); setSelectedIdx(-1); }, [suggestions]);

const choose = (name) => { onChange(name); setOpen(false); inputRef.current?.focus(); };

const handleKey = (e) => {
if (!open) return;
if (e.key === ‘ArrowDown’) { e.preventDefault(); setSelectedIdx(i => Math.min(i + 1, suggestions.length - 1)); }
else if (e.key === ‘ArrowUp’) { e.preventDefault(); setSelectedIdx(i => Math.max(i - 1, -1)); }
else if (e.key === ‘Enter’) {
e.preventDefault();
if (selectedIdx >= 0 && suggestions[selectedIdx]) choose(suggestions[selectedIdx].name);
else if (value.trim()) onSubmit(value.trim());
}
else if (e.key === ‘Escape’) setOpen(false);
};

return (
<div style={{ position: ‘relative’, flex: 1 }}>
<input
ref={inputRef}
type=“text”
value={value}
onChange={e => onChange(e.target.value)}
onKeyDown={handleKey}
onBlur={() => setTimeout(() => setOpen(false), 150)}
onFocus={() => suggestions.length > 0 && setOpen(true)}
placeholder=“Type a player name…”
disabled={disabled}
autoComplete=“off”
/>
{open && (
<div className="autocomplete-list slide-down">
{suggestions.map((p, i) => (
<div key={p.name} className={`autocomplete-item${i === selectedIdx ? ' selected' : ''}`} onMouseDown={() => choose(p.name)}>
<span style={{ marginRight: 8 }}><RankBadge rank={p.rank} /></span>
{p.name}
</div>
))}
</div>
)}
</div>
);
}

